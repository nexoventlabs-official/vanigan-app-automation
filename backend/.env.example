# Environment
NODE_ENV=development
PORT=5050

# CORS (comma separated origins; localhost auto-allowed in dev)
ALLOWED_ORIGINS=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/vanigan?appName=Cluster0

# Admin login (seeded automatically on first run)
ADMIN_USERNAME=admin
# FIX 7.2: ADMIN_PASSWORD must be set — server refuses to start in production without it
# Use a strong password (min 16 chars, mixed case + symbols)
ADMIN_PASSWORD=
SUBADMIN_USERNAME=vanigan
SUBADMIN_PASSWORD=vanigan123

# FIX 7.2: JWT_SECRET must be set — generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Public HTTPS URL of THIS backend (used as the WhatsApp Flow endpoint)
BACKEND_URL=https://your-backend.example.com

# Frontend URL (admin panel) — used in CORS allow-list only
FRONTEND_URL=https://your-admin.example.com
# User website URL (member portal) — used for referral links
USER_WEBSITE_URL=https://your-userwebsite.example.com


# Meta WhatsApp Cloud API
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_WABA_ID=
# FIX 7.2: META_VERIFY_TOKEN must be set — choose a long random string (min 32 chars)
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v22.0

# WhatsApp Flow (filled in by scripts/setup-all.js)
WHATSAPP_FLOW_ID=
WHATSAPP_FLOW_STATUS=DRAFT

# Flow encryption keys (filled in by scripts/setup-all.js)
# FIX 7.3: In production, use a Render Secret File for FLOW_PRIVATE_KEY
# Upload flow_keys/private.pem as a Secret File at /etc/secrets/flow_private.pem
FLOW_PRIVATE_KEY=
FLOW_PUBLIC_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=vanigan

# Gallery Cloudinary (separate account for event gallery)
GALLERY_CLOUDINARY_CLOUD_NAME=
GALLERY_CLOUDINARY_API_KEY=
GALLERY_CLOUDINARY_API_SECRET=
